APP_NAME=Surgify AI Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1

# SQLite — no database server needed
DATABASE_URL=sqlite:///./surgify.db

FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

VISION_MODE=mock
ENABLE_MEDIAPIPE=false
ENABLE_OPENCV=true
UPLOAD_DIR=./uploads
MAX_FRAME_SIZE_MB=5
ARUCO_DICTIONARY=DICT_4X4_50
TOOL_MARKER_H_MIN=80
TOOL_MARKER_H_MAX=110

ENABLE_EXTERNAL_LLM=false
ANTHROPIC_API_KEY=

DEMO_MODE=true
